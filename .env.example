# Copia para .env e preenche com valores reais (nunca comitar .env)

PORT=8787
HOST=0.0.0.0

# Caminho para o CSV de produtos
PRODUCTS_CSV=/caminho/para/Produtos.csv

# Autenticacao da aplicacao (obrigatorio)
POS_AUTH_USER=
POS_AUTH_PASS=
# Opcional: se nao definido, e gerado aleatoriamente a cada arranque (sessoes expiram no restart)
POS_AUTH_SECRET=

# Integracao ZoneSoft (obrigatorio apenas se ZONESOFT_ENABLED=1)
ZONESOFT_ENABLED=0
ZONESOFT_NIF=
ZONESOFT_LOGIN=
ZONESOFT_PASSWORD=
ZONESOFT_ORDER_CLIENT_SEARCH=2
ZONESOFT_SCRIPT=
ZONESOFT_PYTHON=python3
ZONESOFT_TIMEOUT_MS=180000

# Integracao ZSROI (developer.zonesoft.org) - endpoints inbound
# Preencher com o APP-KEY / APP-SECRET gerados ao criar a integracao no portal
ZSROI_APP_KEY=
ZSROI_APP_SECRET=
