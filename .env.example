# Copia para .env e preenche com valores reais (nunca comitar .env)

PORT=8787
HOST=0.0.0.0

# Catalogo de produtos (MariaDB, obrigatorio)
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=pos_products
MARIADB_PASSWORD=
MARIADB_DATABASE=zonesoft_full
PRODUCTS_CACHE_TTL_MS=30000

# Autenticacao da aplicacao (obrigatorio)
POS_AUTH_USER=
POS_AUTH_PASS=
# Opcional: se nao definido, e gerado aleatoriamente a cada arranque (sessoes expiram no restart)
POS_AUTH_SECRET=

# Bridge local para escrever/ler mesas no ZoneSoft (obrigatorio para a funcionalidade de mesas)
BRIDGE_URL=http://localhost:8799
BRIDGE_TOKEN=
BRIDGE_TIMEOUT_MS=8000
TABLE_WATCH_INTERVAL_MS=30000

# Integracao ZoneSoft (obrigatorio apenas se ZONESOFT_ENABLED=1)
ZONESOFT_ENABLED=0
ZONESOFT_NIF=
ZONESOFT_LOGIN=
ZONESOFT_PASSWORD=
ZONESOFT_ORDER_CLIENT_SEARCH=2
ZONESOFT_SCRIPT=
ZONESOFT_PYTHON=python3
ZONESOFT_TIMEOUT_MS=180000

# Integracao ZSROI (developer.zonesoft.org) - endpoints inbound
# Preencher com o APP-KEY / APP-SECRET gerados ao criar a integracao no portal
ZSROI_APP_KEY=
ZSROI_APP_SECRET=
