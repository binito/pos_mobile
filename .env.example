# Copia para .env e preenche com valores reais (nunca comitar .env)

PORT=8787
HOST=0.0.0.0

# Ligacao ao SQL Server do ZoneSoft (autenticacao SQL, obrigatorio)
# Ver setup-database.sql para criar o login dedicado.
# MSSQL_PORT usa uma porta fixa (recomendado - evita depender do servico
# SQL Server Browser). Deixa em branco para usar o nome da instancia em
# MSSQL_SERVER (ex: localhost\ZONESOFTSQL) - requer o SQL Server Browser ativo.
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_USER=pos_online_svc
MSSQL_PASSWORD=
PRODUCTS_CACHE_TTL_MS=30000

# Numero do posto/registo e codigo de empregado a atribuir aos artigos
# enviados para a mesa a partir do pos_online.
ZONESOFT_POSTO=1
ZONESOFT_EMPID=1

# Autenticacao da aplicacao (obrigatorio)
POS_AUTH_USER=
POS_AUTH_PASS=
# Opcional: se nao definido, e gerado aleatoriamente a cada arranque (sessoes expiram no restart)
POS_AUTH_SECRET=

TABLE_WATCH_INTERVAL_MS=30000

# Integracao ZoneSoft (obrigatorio apenas se ZONESOFT_ENABLED=1)
ZONESOFT_ENABLED=0
ZONESOFT_NIF=
ZONESOFT_LOGIN=
ZONESOFT_PASSWORD=
ZONESOFT_ORDER_CLIENT_SEARCH=2
ZONESOFT_SCRIPT=
ZONESOFT_PYTHON=python3
ZONESOFT_TIMEOUT_MS=180000

# Integracao ZSROI (developer.zonesoft.org) - endpoints inbound
ZSROI_APP_KEY=
ZSROI_APP_SECRET=
